# Roamie Pro — Environment Configuration
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=file:./dev.db
# For PostgreSQL (production/docker):
# DATABASE_URL=postgresql://roamie:roamie@localhost:5432/roamie_production

# ═══════════════════════════════════════════════════════════════
# Authentication
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_characters

# ═══════════════════════════════════════════════════════════════
# AI / LLM Configuration
# ═══════════════════════════════════════════════════════════════
# AWS Bedrock (primary)
AWS_REGION=us-east-1
USE_BEDROCK=true

# Anthropic direct API (alternative to Bedrock)
ANTHROPIC_API_KEY=

# Ollama (local fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ═══════════════════════════════════════════════════════════════
# AWS Services
# ═══════════════════════════════════════════════════════════════
S3_BUCKET=your-s3-bucket-name

# ═══════════════════════════════════════════════════════════════
# Application
# ═══════════════════════════════════════════════════════════════
FRONTEND_URL=http://localhost:5173
PORT=3001

# Twilio SMS (primary provider for flight disruption alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Notification target (E.164 format, e.g. +919876543210)
NOTIFICATION_PHONE=
